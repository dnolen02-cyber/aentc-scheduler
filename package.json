{
  "name": "aentc-scheduler",
  "version": "1.0.0",
  "description": "AENTC Scheduling Assistant",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "cd client && npm run dev",
    "install:all": "npm install --cache /tmp/npm-cache && cd client && npm install --cache /tmp/npm-cache",
    "build": "cd client && npm run build",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.0.0",
    "concurrently": "^9.0.0",
    "cors": "^2.8.5",
    "csv-stringify": "^6.5.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.15",
    "uuid": "^10.0.0"
  }
}
