modules = ["nodejs-20"]

[nix]
channel = "stable-24_05"

# Workspace Run button — starts the dev server (hot-reload for both client and server)
run = "npm run dev"

[[ports]]
localPort = 3001
externalPort = 80

# ── Production Deployment ──────────────────────────────────────────────────────
# Click "Deploy" in Replit to use these settings.
# Build: installs all deps and compiles the React client.
# Run:   starts Express which serves the built client as static files.

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "npm install --cache /tmp/npm-cache && cd client && npm install --cache /tmp/npm-cache && cd .. && npm run build"]
run = ["sh", "-c", "NODE_ENV=production node server/index.js"]
